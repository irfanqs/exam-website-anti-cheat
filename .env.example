# Salin file ini menjadi .env dan isi sesuai environment Anda.

# --- Database (PostgreSQL) ---
# Lokal cepat: npx prisma dev --detach
#
# Kalau pakai Supabase (Project Settings -> Database -> Connection string):
# - DATABASE_URL  = "Transaction" pooler, port 6543 (dipakai app saat runtime di Vercel;
#                    serverless butuh connection pooling karena tiap invocation buka koneksi baru)
# - DIRECT_URL    = "Direct connection", port 5432 (dipakai HANYA saat migrasi/db push,
#                    karena DDL tidak didukung lewat pooler transaksi)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"
DIRECT_URL=

# NextAuth (Auth.js v5) — wajib diisi, dipakai untuk menandatangani session admin.
# Generate dengan: openssl rand -base64 32
AUTH_SECRET=

# Akun admin awal yang dibuat oleh `npm run db:seed` (opsional, ada default jika kosong)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
